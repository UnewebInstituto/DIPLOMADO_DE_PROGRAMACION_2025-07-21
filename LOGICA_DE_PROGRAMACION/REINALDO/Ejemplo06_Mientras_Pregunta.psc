Algoritmo Ejemplo06_Mientras_Pregunta
	//Declaracion de variables
	Definir i Como Entero
	Definir n  Como Entero
	//Inicializacion de variables
	n <- 0
	i <- 0
	//Proceso 
	escribir 'ingrese el numero de iteraciones a ejecutar:'
	leer n
	Mientras i < n Hacer
		Escribir i
		i <- i + 1
	FinMientras
FinAlgoritmo
